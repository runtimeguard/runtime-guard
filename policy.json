{
  "blocked": {
    "commands": [
      "rm -rf",
      "rm -rf /",
      "rm -rf ~",
      "mkfs",
      "shutdown",
      "reboot",
      "halt",
      "poweroff",
      "fdisk",
      "parted",
      "diskutil erasedisk",
      "format",
      "dd",
      "sudo",
      "su",
      "doas"
    ],
    "paths":    [".env", ".ssh", "/etc/passwd", "activity.log", "approvals.db", "approvals.db.hmac.key"],
    "extensions": [".pem", ".key"]
  },

  "requires_confirmation": {
    "commands": [
      "cat",
      "find",
      "tar",
      "zip",
      "unzip",
      "curl",
      "wget",
      "scp",
      "rsync",
      "git push",
      "chmod -r",
      "chown -r",
      "cp -r",
      "sed -i",
      "perl -pi",
      "rm",
      "mv",
      "git clone",
      "git fetch",
      "git reset --hard",
      "git clean -fd",
      "mail",
      "mailx",
      "sendmail",
      "pip install",
      "pip3 install",
      "npm install",
      "brew install",
      "apt install",
      "yum install",
      "dnf install",
      "kill",
      "pkill",
      "nohup",
      "crontab",
      "launchctl",
      "systemctl",
      "base64",
      "xxd",
      "nc",
      "netcat",
      "sqlite3",
      "tail",
      "grep",
      "awk",
      "sed",
      "head",
      "less"
    ],
    "paths": [
      "/etc",
      ".git",
      ".aws",
      ".config",
      "/var/log",
      "activity.log",
      "approvals.db"
    ],
    "session_whitelist_enabled": true,
    "approval_security": {
      "max_failed_attempts_per_token": 5,
      "failed_attempt_window_seconds": 600
    }
  },

  "requires_simulation": {
    "commands": [
      "rm",
      "mv",
      "cp",
      "rsync",
      "find",
      "xargs",
      "sed",
      "perl"
    ],
    "bulk_file_threshold": 10,
    "max_retries": 3,
    "cumulative_budget": {
      "enabled": true,
      "scope": "session",
      "limits": {
        "max_unique_paths": 50,
        "max_total_operations": 100,
        "max_total_bytes_estimate": 104857600
      },
      "counting": {
        "mode": "affected_paths",
        "dedupe_paths": true,
        "include_noop_attempts": false,
        "commands_included": ["rm", "mv", "write_file", "delete_file"]
      },
      "reset": {
        "mode": "sliding_window",
        "window_seconds": 3600,
        "idle_reset_seconds": 900,
        "reset_on_server_restart": true
      },
      "on_exceed": {
        "decision_tier": "blocked",
        "matched_rule": "requires_simulation.cumulative_budget_exceeded",
        "message": "Cumulative blast-radius budget exceeded for current scope."
      },
      "overrides": {
        "enabled": true,
        "require_confirmation_tool": "out_of_band_operator_approval",
        "token_ttl_seconds": 300,
        "max_override_actions": 1,
        "audit_reason_required": true,
        "allowed_roles": ["human-operator"]
      },
      "audit": {
        "log_budget_state": true,
        "fields": [
          "budget_scope",
          "budget_key",
          "cumulative_unique_paths",
          "cumulative_total_operations",
          "cumulative_total_bytes_estimate",
          "budget_remaining"
        ]
      }
    }
  },

  "allowed": {
    "paths_whitelist": [],
    "max_files_per_operation": 10,
    "max_file_size_mb": 10,
    "max_directory_depth": 5
  },

  "network": {
    "_comment": "Network policy for command execution. enforcement_mode supports: off, monitor, enforce",
    "enforcement_mode": "enforce",
    "commands": [
      "curl",
      "wget",
      "scp",
      "sftp",
      "rsync",
      "ssh",
      "nc",
      "netcat",
      "http",
      "https"
    ],
    "allowed_domains": [],
    "blocked_domains": [],
    "max_payload_size_kb": 1024
  },

  "execution": {
    "max_command_timeout_seconds": 30,
    "max_output_chars": 200000
  },

  "backup_access": {
    "_comment": "Protect backup storage from regular agent file tools; restore_backup remains the controlled path",
    "block_agent_tools": true,
    "allowed_tools": ["restore_backup"]
  },

  "restore": {
    "_comment": "Restore flow controls; when enabled, dry_run=true must be called first to obtain restore_token",
    "require_dry_run_before_apply": true,
    "confirmation_ttl_seconds": 300
  },

  "audit": {
    "_comment": "Audit and backup settings — backup_enabled is read by the server at startup",
    "backup_enabled": true,
    "backup_on_content_change_only": true,
    "max_versions_per_file": 5,
    "backup_retention_days": 30,
    "log_level": "verbose",
    "redact_patterns": [
      "(?i)(api[_-]?key\\s*[=:]\\s*)([^\\s]+)",
      "(?i)(token\\s*[=:]\\s*)([^\\s]+)",
      "(?i)(password\\s*[=:]\\s*)([^\\s]+)",
      "(?i)(secret\\s*[=:]\\s*)([^\\s]+)"
    ]
  }
}
